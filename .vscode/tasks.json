{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "g++ -g ${workspaceFolder}/main.cpp -o ${workspaceFolder}/sfml_app -lsfml-graphics -lsfml-window -lsfml-system && ${workspaceFolder}/sfml_app",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}